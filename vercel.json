{
  "functions": {
    "main.py": {
      "excludeFiles": "(.venv/**|venv/**|env/**|*.db)"
    }
  },
  "rewrites": [
    { "source": "/inregistrare", "destination": "/main.py" },
    { "source": "/autentificare", "destination": "/main.py" },
    { "source": "/sarcini", "destination": "/main.py" },
    { "source": "/sarcini/(.*)", "destination": "/main.py" },
    { "source": "/healthz", "destination": "/main.py" },
    { "source": "/(.*)", "destination": "/static/index.html" }
  ]
}
