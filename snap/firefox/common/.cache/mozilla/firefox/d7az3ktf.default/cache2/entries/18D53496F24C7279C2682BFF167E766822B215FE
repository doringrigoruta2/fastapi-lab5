<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestionar Sarcini</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="#">рЯУЭ TaskManager</a>
            <span class="navbar-text ms-auto text-white fw-bold" id="contor-sarcini">
                0 sarcini / 0 finalizate
            </span>
            <button class="btn btn-outline-light btn-sm ms-3" id="btn-deconectare" onclick="deconectare()" style="display: none;">Deconectare</button>
        </div>
    </nav>

    <div class="container" style="max-width: 800px;">
        
        <div id="sectiune-Atenfificare" class="card card-body shadow-sm mb-4">
            <h4 class="card-title text-center mb-3">Autentificare</h4>
            <div class="mb-3">
                <label class="form-label">Nume utilizator</label>
                <input type="text" id="auth-username" class="form-control" placeholder="username">
            </div>
            <div class="mb-3">
                <label class="form-label">ParolƒГ</label>
                <input type="password" id="auth-password" class="form-control" placeholder="parola">
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-primary w-50" onclick="autentificare()">IntrƒГ √Ѓn cont</button>
                <button class="btn btn-outline-secondary w-50" onclick="inregistrare()">√Оnregistrare cont nou</button>
            </div>
        </div>

        <div id="sectiune-Aplicatie" style="display: none;">
            
            <div class="card card-body shadow-sm mb-4">
                <h5>AdaugƒГ o sarcinƒГ nouƒГ</h5>
                <div class="mb-3">
                    <input type="text" id="task-titlu" class="form-control" placeholder="Titlul sarcinii...">
                </div>
                <div class="mb-3">
                    <textarea id="task-descriere" class="form-control" placeholder="Descrierea sarcinii..."></textarea>
                </div>
                <button class="btn btn-success" onclick="creazaSarcina()">AdaugƒГ SarcinƒГ</button>
            </div>

            <div class="card card-body shadow-sm mb-4">
                <div class="mb-3">
                    <label class="form-label fw-bold">CƒГutare rapidƒГ:</label>
                    <input type="text" id="cautare-task" class="form-control" placeholder="FiltreazƒГ instant dupƒГ titlu..." oninput="filtreazaDupaTitlu()">
                </div>

                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="doar-nefinalizate" onchange="incarcaSarcini()">
                    <label class="form-check-label fw-bold" for="doar-nefinalizate">
                        Afi»ЩeazƒГ doar sarcinile nefinalizate
                    </label>
                </div>
            </div>

            <h5 class="mb-3">Sarcinile mele</h5>
            <div id="lista-sarcini"></div>

        </div>
    </div>

    <script>
        const API = "http://localhost:8000";
        let toateSarciniGlobal = []; // BONUS 3: Memorie globalƒГ pentru filtrare pe client

        // VerificƒГm dacƒГ utilizatorul este deja logat la deschiderea paginii
        window.onload = function() {
            const token = localStorage.getItem("token");
            if (token) {
                arataAplicatie();
            }
        };

        function arataAplicatie() {
            document.getElementById("sectiune-Atenfificare").style.display = "none";
            document.getElementById("sectiune-Aplicatie").style.display = "block";
            document.getElementById("btn-deconectare").style.display = "block";
            incarcaSarcini();
        }

        function deconectare() {
            localStorage.removeItem("token");
            document.getElementById("sectiune-Atenfificare").style.display = "block";
            document.getElementById("sectiune-Aplicatie").style.display = "none";
            document.getElementById("btn-deconectare").style.display = "none";
            document.getElementById("contor-sarcini").textContent = "0 sarcini / 0 finalizate";
        }

        // POST /inregistrare
        async function inregistrare() {
            const u = document.getElementById("auth-username").value;
            const p = document.getElementById("auth-password").value;
            if(!u || !p) { alert("CompleteazƒГ username »Щi parola!"); return; }
            
            try {
                const raspuns = await fetch(`${API}/inregistrare`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ username: u, parola: p })
                });
                const date = await raspuns.json();
                if (raspuns.ok) {
                    alert("Cont creat cu succes! Acum te po»Ыi autentifica.");
                } else {
                    alert("Eroare: " + (date.detail || "Nu s-a putut crea contul."));
                }
            } catch (err) { console.error(err); }
        }

        // POST /autentificare (Corectat pentru OAuth2PasswordRequestForm)
        async function autentificare() {
            const u = document.getElementById("auth-username").value;
            const p = document.getElementById("auth-password").value;
            if(!u || !p) { alert("CompleteazƒГ username »Щi parola!"); return; }
            
            const corpFormular = new URLSearchParams();
            corpFormular.append("username", u);
            corpFormular.append("password", p); // Sincronizat exact cu backend-ul

            try {
                const raspuns = await fetch(`${API}/autentificare`, {
                    method: "POST",
                    headers: { "Content-Type": "application/x-www-form-urlencoded" },
                    body: corpFormular
                });
                const date = await raspuns.json();
                if (raspuns.ok) {
                    localStorage.setItem("token", date.access_token);
                    arataAplicatie();
                } else {
                    alert("Autentificare e»ЩuatƒГ: " + (date.detail || "Date incorecte."));
                }
            } catch (err) { console.error(err); }
        }

        // GET /sarcini (Modificat pentru CERIN»ЪA B)
        async function incarcaSarcini() {
            const token = localStorage.getItem("token");
            if (!token) return;

            // CERIN»ЪA B: Verificare dacƒГ filtrul este bifat
            const doarNefinalizate = document.getElementById("doar-nefinalizate").checked;
            const url = doarNefinalizate ? `${API}/sarcini?doar_nefinalizate=true` : `${API}/sarcini`;

            try {
                const raspuns = await fetch(url, {
                    headers: { "Authorization": `Bearer ${token}` }
                });
                if (raspuns.ok) {
                    const sarcini = await raspuns.json();
                    toateSarciniGlobal = sarcini; // SalveazƒГ copia pentru BONUS CƒГutare
                    randeazaSarcini(sarcini);
                }
            } catch (err) { console.error(err); }
        }

        // RANDARE LISTƒВ (Modificat pentru CERIN»ЪA A »Щi BONUS CONTOR)
        function randeazaSarcini(sarcini) {
            // BONUS 1: Calculare valori contor din navbar
            const totalSarcini = sarcini.length;
            const sarciniFinalizate = sarcini.filter(s => s.finalizata).length;
            document.getElementById("contor-sarcini").textContent = `${totalSarcini} sarcini / ${sarciniFinalizate} finalizate`;

            const container = document.getElementById("lista-sarcini");
            container.innerHTML = "";

            if (sarcini.length === 0) {
                container.innerHTML = `<p class="text-muted text-center mt-3">Nu existƒГ sarcini.</p>`;
                return;
            }

            sarcini.forEach(s => {
                const html = `
                    <div class="card mb-2 shadow-sm">
                        <div class="card-body" id="sarcina-body-${s.id}">
                            <h5 class="card-title ${s.finalizata ? 'text-decoration-line-through text-muted' : ''}">${s.titlu}</h5>
                            <p class="card-text text-secondary">${s.descriere || "<i>FƒГrƒГ descriere</i>"}</p>
                            
                            <div class="d-flex gap-2 mt-2">
                                ${!s.finalizata ? `<button class="btn btn-sm btn-success" onclick="finalizeazaSarcina(${s.id})">FinalizeazƒГ</button>` : ''}
                                <button class="btn btn-sm btn-outline-primary" onclick="editeazaSarcina(${s.id}, '${s.titlu}', '${s.descriere || ''}')">EditeazƒГ</button>
                                <button class="btn btn-sm btn-danger" onclick="stergeSarcina(${s.id})">»Шterge</button>
                            </div>
                        </div>
                    </div>
                `;
                container.innerHTML += html;
            });
        }

        // POST /sarcini
        async function creazaSarcina() {
            const token = localStorage.getItem("token");
            const t = document.getElementById("task-titlu").value;
            const d = document.getElementById("task-descriere").value;

            if(!t) { alert("Titlul este obligatoriu!"); return; }

            try {
                const raspuns = await fetch(`${API}/sarcini`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "Authorization": `Bearer ${token}`
                    },
                    body: JSON.stringify({ titlu: t, descriere: d })
                });
                if (raspuns.ok) {
                    document.getElementById("task-titlu").value = "";
                    document.getElementById("task-descriere").value = "";
                    incarcaSarcini();
                }
            } catch (err) { console.error(err); }
        }

        // PATCH /sarcini/{id}/finalizeaza
        async function finalizeazaSarcina(id) {
            const token = localStorage.getItem("token");
            try {
                const raspuns = await fetch(`${API}/sarcini/${id}/finalizeaza`, {
                    method: "PATCH",
                    headers: { "Authorization": `Bearer ${token}` }
                });
                if (raspuns.ok) {
                    incarcaSarcini();
                }
            } catch (err) { console.error(err); }
        }

        // DELETE /sarcini/{id} (Modificat pentru BONUS CONFIRMARE)
        async function stergeSarcina(id) {
            // BONUS 2: Confirmare stergere
            const sigur = window.confirm("E»Щti sigur cƒГ vrei sƒГ »Щtergi aceastƒГ sarcinƒГ?");
            if (!sigur) return;

            const token = localStorage.getItem("token");
            try {
                const raspuns = await fetch(`${API}/sarcini/${id}`, {
                    method: "DELETE",
                    headers: { "Authorization": `Bearer ${token}` }
                });
                if (raspuns.ok) {
                    incarcaSarcini();
                }
            } catch (err) { console.error(err); }
        }

        // CERIN»ЪA A: Modificarea cardului √Ѓn input-uri
        function editeazaSarcina(id, titluCurent, descriereCurenta) {
            const cardBody = document.getElementById(`sarcina-body-${id}`);
            cardBody.innerHTML = `
                <div class="mb-2">
                    <label class="small fw-bold">Titlu nou:</label>
                    <input type="text" id="edit-titlu-${id}" class="form-control form-control-sm" value="${titluCurent}">
                </div>
                <div class="mb-2">
                    <label class="small fw-bold">Descriere nouƒГ:</label>
                    <textarea id="edit-descriere-${id}" class="form-control form-control-sm" rows="2">${descriereCurenta}</textarea>
                </div>
                <button class="btn btn-sm btn-primary" onclick="salveazaEditare(${id})">SalveazƒГ</button>
                <button class="btn btn-sm btn-secondary" onclick="incarcaSarcini()">AnuleazƒГ</button>
            `;
        }

        // CERIN»ЪA A: Trimiterea request-ului PUT
        async function salveazaEditare(id) {
            const token = localStorage.getItem("token");
            const titluNou = document.getElementById(`edit-titlu-${id}`).value;
            const descriereNoua = document.getElementById(`edit-descriere-${id}`).value;

            try {
                const raspuns = await fetch(`${API}/sarcini/${id}`, {
                    method: "PUT",
                    headers: {
                        "Content-Type": "application/json",
                        "Authorization": `Bearer ${token}`
                    },
                    body: JSON.stringify({ titlu: titluNou, descriere: descriereNoua })
                });

                if (raspuns.ok) {
                    incarcaSarcini();
                } else {
                    alert("Eroare la salvarea modificƒГrilor.");
                }
            } catch (err) { console.error(err); }
        }

        // BONUS 3: Filtrare localƒГ pe client (dupƒГ titlu)
        function filtreazaDupaTitlu() {
            const textCautat = document.getElementById("cautare-task").value.toLowerCase();
            const sarciniFiltrate = toateSarciniGlobal.filter(s => 
                s.titlu.toLowerCase().includes(textCautat)
            );
            randeazaSarcini(sarciniFiltrate);
        }
    </script>
</body>
</html>
